{
  "name": "austria-2026",
  "version": "0.1.0",
  "description": "Allison + Avital — Salzburg July 24-31 2026. Two trip-itinerary options with live note feedback.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,html,css}\" \"*.{html,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css}\" \"*.{html,json,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
